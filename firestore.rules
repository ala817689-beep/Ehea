rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Professional Validation
    function isValidProfessional(data) {
      return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100 &&
             data.phone is string && data.phone.matches('^07[0-9]{8,9}$') &&
             data.mainProfession is string &&
             data.province is string &&
             data.area is string &&
             data.userId == request.auth.uid;
    }

    // --- Collections ---
    
    match /professionals/{professionalId} {
      allow read: if true; // Public profiles
      allow create: if isSignedIn() && professionalId == request.auth.uid && isValidProfessional(incoming());
      allow update: if isSignedIn() && isOwner(professionalId) && isValidProfessional(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phone', 'mainProfession', 'subSkills', 'province', 'area', 'portfolioImages', 'status'])
      );
    }

    match /professionals/{professionalId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && 
                    incoming().professionalId == professionalId &&
                    incoming().rating >= 1 && incoming().rating <= 5;
    }

    match /professionals/{professionalId}/transactions/{transactionId} {
      allow read: if isOwner(professionalId);
      // Transactions should ideally be system-managed, but for MVP we might allow deposit tracking
      allow create: if isOwner(professionalId) && incoming().type == 'deposit';
    }
  }
}
